{
    "name": "iptv-pro-player",
    "version": "1.0.0",
    "description": "Premium IPTV Player for Windows",
    "main": "main.js",
    "author": "prodbyabdo",
    "license": "MIT",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win",
        "build:portable": "electron-builder --win portable"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.prodbyabdo.iptvplayer",
        "productName": "IPTV Pro Player",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "iptv-pro-player.html",
            "sports-center.html",
            "football-api.js",
            "omdb-api.js",
            "icon.png"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}